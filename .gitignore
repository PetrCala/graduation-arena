# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.python-version

# Node / SvelteKit
node_modules/
.svelte-kit/
build/
dist/

# Firebase (CLI cache + logs; config files firebase.json/.firebaserc are tracked)
.firebase/
firebase-debug.log
*-debug.log

# Environment
.env
.env.*

# OS
.DS_Store
Thumbs.db

# Pipeline output: per-evaluator aggregates are a CI build artifact, not committed
# (personal data — see docs/app-architecture.md). The dir is kept via .gitkeep.
data/aggregates/*.json

# Claude Code per-session worktrees — never commit these.
.claude/worktrees/

# Local per-user Claude Code settings (kept out of version control).
.claude/settings.local.json
